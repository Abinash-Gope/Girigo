{
  "expo": {
    "name": "Girigo",
    "slug": "Girigo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/praying_hands.png",
    "scheme": "girigo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#171417",
        "foregroundImage": "./assets/praying_hands.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/praying_hands.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.v3nomabi.Girigo"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/praying_hands.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/praying_hands.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#171417",
          "dark": {
            "backgroundColor": "#171417"
          }
        }
      ],
      "expo-video",
      [
        "expo-camera",
        {
          "cameraPermission": "Girigo requires access to your camera for the ritual.",
          "microphonePermission": "Girigo requires access to your microphone for the ritual.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#8A0303"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "buildArchs": ["arm64-v8a"]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bc79a1c2-278d-4f38-8cf5-fa99f8ab96b6"
      }
    },
    "owner": "v3nomabi"
  }
}
